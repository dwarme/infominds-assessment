# Copy to .env.local and fill in your OpenAI credentials.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional. Used for document embeddings (RAG). Defaults to text-embedding-3-small.
# Uses the same OPENAI_API_KEY as chat — no second provider key required.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
